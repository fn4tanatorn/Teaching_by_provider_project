    {
      "id": "7-important-comparisons",
      "number": 7,
      "title": "Important Comparisons",
      "layout": "left",
      "reveal": "left",
      "blocks": [
        {
          "type": "text",
          "content": "Epinephrine vs Norepinephrine"
        },
        {
          "type": "table",
          "header": [
            "Feature",
            "Epinephrine",
            "Norepinephrine"
          ],
          "rows": [
            [
              "Receptors",
              "alpha1, alpha2, beta1, beta2",
              "alpha1, alpha2, beta1"
            ],
            [
              "beta2 activity",
              "Strong",
              "Minimal"
            ],
            [
              "Diastolic BP",
              "May decrease at low dose",
              "Increases"
            ],
            [
              "Heart rate",
              "Increases",
              "Reflex bradycardia possible"
            ],
            [
              "Best use",
              "Anaphylaxis",
              "Septic shock"
            ]
          ]
        },
        {
          "type": "text",
          "content": "Phenylephrine vs Isoproterenol"
        },
        {
          "type": "table",
          "header": [
            "Feature",
            "Phenylephrine",
            "Isoproterenol"
          ],
          "rows": [
            [
              "Main receptor",
              "alpha1",
              "beta1, beta2"
            ],
            [
              "BP effect",
              "↑ BP",
              "↓ mean BP"
            ],
            [
              "HR effect",
              "Reflex ↓ HR",
              "Marked ↑ HR"
            ],
            [
              "Use",
              "Decongestant, mydriasis, hypotension",
              "Rare"
            ]
          ]
        },
        {
          "type": "text",
          "content": "Dobutamine vs Dopamine"
        },
        {
          "type": "table",
          "header": [
            "Feature",
            "Dobutamine",
            "Dopamine"
          ],
          "rows": [
            [
              "Main action",
              "beta1 inotrope",
              "Traditional D1/beta1/alpha1 dose pattern"
            ],
            [
              "Use",
              "Acute HF, stress test",
              "Shock historically"
            ],
            [
              "Major risk",
              "Tachyarrhythmia",
              "More arrhythmias"
            ]
          ]
        },
        {
          "type": "text",
          "content": "Direct vs Indirect Sympathomimetics"
        },
        {
          "type": "table",
          "header": [
            "Direct",
            "Indirect"
          ],
          "rows": [
            [
              "Bind receptors directly",
              "Increase endogenous catecholamines"
            ],
            [
              "Work even if NE stores depleted",
              "Require catecholamine stores"
            ],
            [
              "Examples: epinephrine, phenylephrine",
              "Examples: amphetamine, tyramine, cocaine"
            ]
          ]
        }
      ],
      "image": "data_9/08-table-9-4.png",
      "imageCaption": "TABLE 9-4 — Cardiovascular responses to sympathomimetics"
    },
    {
      "id": "8-must-know-exam-points",
      "number": 8,
      "title": "Must-Know Exam Points",
      "layout": "right",
      "reveal": "right",
      "blocks": [
        {
          "type": "list",
          "items": [
            "alpha1 = vasoconstriction, mydriasis, urinary retention.",
            "alpha2 = decreased sympathetic outflow.",
            "beta1 = heart stimulation.",
            "beta2 = bronchodilation, uterine relaxation, hypokalemia.",
            "beta3 = bladder relaxation.",
            "D1 = renal vasodilation.",
            "Epinephrine is first-line for anaphylaxis.",
            "Norepinephrine is preferred vasopressor in septic shock.",
            "Phenylephrine causes reflex bradycardia.",
            "Midodrine treats orthostatic hypotension but can cause supine hypertension.",
            "Clonidine withdrawal causes rebound hypertension.",
            "MAOI + tyramine causes hypertensive crisis.",
            "Cocaine blocks catecholamine reuptake and can cause MI.",
            "Dobutamine is used in cardiac stress testing and acute heart failure.",
            "Albuterol toxicity includes tremor, tachycardia, and hypokalemia.",
            "Mirabegron treats overactive bladder via beta3 activation."
          ]
        }
      ],
      "image": "data_9/13-fig-9-8.png",
