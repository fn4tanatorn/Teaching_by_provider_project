    },
    {
      "id": "6-adverse-effects-toxicity-pitfalls",
      "number": 6,
      "title": "Adverse Effects / Toxicity / Pitfalls",
      "layout": "center",
      "reveal": "up",
      "blocks": [
        {
          "type": "subheading",
          "content": "Muscarinic Excess"
        },
        {
          "type": "list",
          "items": [
            "DUMBELS:",
            "Diarrhea",
            "Urination",
            "Miosis",
            "Bronchospasm/bronchorrhea/bradycardia",
            "Emesis",
            "Lacrimation",
            "Salivation/sweating",
            "Major life threats:",
            "Bronchospasm",
            "Bronchorrhea",
            "Bradycardia",
            "Respiratory failure"
          ]
        },
        {
          "type": "subheading",
          "content": "Nicotinic Excess"
        },
        {
          "type": "list",
          "items": [
            "Fasciculations",
            "Muscle cramps",
            "Weakness",
            "Paralysis",
            "Hypertension/tachycardia from sympathetic ganglionic stimulation"
          ]
        },
        {
          "type": "subheading",
          "content": "CNS Excess"
        },
        {
          "type": "list",
          "items": [
            "Agitation",
            "Confusion",
            "Seizures",
            "Coma",
            "Respiratory arrest"
          ]
        },
        {
          "type": "subheading",
          "content": "Organophosphate Poisoning"
        },
        {
          "type": "list",
          "items": [
            "Irreversible/very long AChE inhibition.",
            "Found in insecticides and nerve agents.",
            "Causes muscarinic + nicotinic + CNS toxicity.",
            "“Aging” makes AChE-organophosphate bond resistant to pralidoxime.",
            "Treat quickly before aging occurs."
          ]
        },
        {
          "type": "subheading",
          "content": "Treatment of Organophosphate Poisoning"
        },
        {
          "type": "subheading",
          "content": "1. ABCs: airway, breathing, circulation"
        },
        {
          "type": "group",
          "label": "2. Decontaminate",
          "items": [
            "Remove clothing",
            "Wash skin",
            "Protect healthcare workers"
          ]
        },
        {
          "type": "group",
          "label": "3. Atropine",
          "items": [
            "Treats muscarinic toxicity",
            "Give until bronchorrhea/bronchospasm/bradycardia improve"
          ]
        },
        {
          "type": "group",
          "label": "4. Pralidoxime (2-PAM)",
          "items": [
            "Regenerates AChE before aging",
            "Treats nicotinic weakness/fasciculations"
          ]
        },
        {
          "type": "group",
          "label": "5. Benzodiazepines",
          "items": [
            "For seizures/agitation"
          ]
        },
        {
          "type": "group",
          "label": "6. Respiratory support",
          "items": [
            "Often required"
          ]
        },
        {
          "type": "subheading",
          "content": "High-Yield Pitfalls"
        },
        {
          "type": "list",
          "items": [
            "Atropine does not reverse nicotinic paralysis.",
            "Pralidoxime works best before organophosphate aging.",
            "Physostigmine crosses the BBB; neostigmine does not.",
            "Bethanechol is contraindicated in mechanical obstruction.",
            "Cholinesterase inhibitors can worsen asthma/COPD due to bronchoconstriction.",
            "Cholinesterase inhibitors can cause bradycardia and AV block."
          ]
        }
      ],
      "image": "data_7/10-fig-7-7.png",
      "imageCaption": "FIGURE 7-7 — Organophosphate cholinesterase inhibitors",
      "imageSupplement": "data_7/09-fig-7-6.png",
      "imageSupplementCaption": "FIGURE 7-6 — Cholinesterase inhibitors (neostigmine)"
    },
