    {
      "id": "24-disease-effects",
      "number": 24,
      "title": "Disease Effects",
      "layout": "center",
      "reveal": "up",
      "blocks": [
        {
          "type": "group",
          "label": "Liver disease",
          "items": [
            "Reduces metabolism of many drugs",
            "Prolongs half-life",
            "Increases toxicity risk"
          ]
        },
        {
          "type": "group",
          "label": "Examples",
